{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "f=\"${CLAUDE_PROJECT_DIR:-$PWD}/PROMPT_COUNTER.md\"; [ -f \"$f\" ] && perl -i -pe 's/^(Count:\\s*)(\\d+)/$1.($2+1)/e' \"$f\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
